# Token do bot Telegram (BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# IDs Telegram autorizados (separados por vírgula)
# Mande /start no bot pra ver seu ID nos logs
ALLOWED_USER_IDS=123456789

# Path absoluto do vault clonado na VPS
VAULT_PATH=/opt/vault

# Branch do vault no git
VAULT_BRANCH=main

# Auto commit/push após cada lançamento
AUTO_PUSH=true
